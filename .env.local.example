# Copy to .env.local and fill in. Get these from your Supabase project settings.

# --- Public (sent to browser) ---
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=YOUR-ANON-KEY

# Secret used to sign the daily QR token (any long random string).
QR_SECRET=change-me-to-a-long-random-string

# --- Server only (NEVER sent to browser) ---
# Service role key — used ONLY by the /admin page to manage bars.
# Supabase → Project Settings → API → service_role (secret). Keep it private.
SUPABASE_SERVICE_ROLE_KEY=YOUR-SERVICE-ROLE-KEY

# Password to access the /admin page.
ADMIN_PASSWORD=set-a-strong-admin-password

# Password for staff to access the /staff/<bar> drink-orders screen.
STAFF_PASSWORD=set-a-staff-password

# Google Places API key — used by /admin to search for a bar by name.
# Google Cloud → enable "Places API (New)" → Credentials → create API key.
GOOGLE_MAPS_API_KEY=YOUR-GOOGLE-PLACES-KEY
